{
  "name": "qr-entry-web-local",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c auto \"npm:dev -w backend\" \"npm:dev -w frontend\"",
    "build": "npm run build -w frontend",
    "start": "npm start -w backend",
    "lint": "npm run lint -w frontend && npm run lint -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}